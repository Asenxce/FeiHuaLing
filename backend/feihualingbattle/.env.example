# ==================== 飞花令对战系统 - 环境变量配置模板 ====================
# 使用方法：复制此文件为 .env ，填入真实值后
#   - IDEA运行：在Run Configuration中添加 Environment Variables
#   - 命令行：export $(cat .env | xargs) 然后 mvn spring-boot:run
# ======================================================================

# Server
SERVER_PORT=8081

# MySQL Database
DB_URL=jdbc:mysql://localhost:3306/feihualingbattle?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (请生成一个至少256位的随机密钥)
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_256_bits

# 阿里云OSS
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY=your_access_key_id_here
OSS_ACCESS_SECRET=your_access_key_secret_here
OSS_BUCKET=your_bucket_name
OSS_DOMAIN=https://your_bucket.oss-cn-beijing.aliyuncs.com
