<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影 - 负边距向外扩展 -->
    <item
        android:top="-2dp"
        android:left="-2dp"
        android:right="-2dp"
        android:bottom="-4dp">
        <shape>
            <corners android:radius="18dp" />
            <solid android:color="#0A2A3A4A" />
        </shape>
    </item>
    
    <!-- 主体层 -->
    <item>
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="@color/poetry_paper" />
            <stroke
                android:width="0.5dp"
                android:color="@color/poetry_border" />
        </shape>
    </item>
</layer-list>
