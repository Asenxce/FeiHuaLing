<?xml version="1.0" encoding="utf-8"?>
<!-- 诗词预览卡片 V2 — 精致古风卡片，金色边框装饰 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外层光晕阴影 -->
    <item android:bottom="6dp" android:left="3dp" android:right="3dp" android:top="3dp">
        <shape>
            <corners android:radius="@dimen/radius_large" />
            <solid android:color="#15B89B5E" />
        </shape>
    </item>

    <!-- 中层阴影 -->
    <item android:bottom="3dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape>
            <corners android:radius="@dimen/radius_large" />
            <solid android:color="#10000000" />
        </shape>
    </item>

    <!-- 金色细边框 -->
    <item>
        <shape>
            <corners android:radius="@dimen/radius_large" />
            <stroke
                android:width="1dp"
                android:color="#30B89B5E" />
            <solid android:color="#FAFAF6" />
        </shape>
    </item>
</layer-list>
