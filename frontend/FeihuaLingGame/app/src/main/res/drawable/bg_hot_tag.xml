<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/poetry_card_background" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/poetry_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/poetry_card_alt" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/poetry_divider" />
        </shape>
    </item>
</selector>
