<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影 - 负边距向外扩展 -->
    <item
        android:top="-2dp"
        android:left="-2dp"
        android:right="-2dp"
        android:bottom="-4dp">
        <shape android:shape="oval">
            <solid android:color="#0A2A3A4A" />
        </shape>
    </item>
    
    <!-- 主体圆环 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/poetry_card_background" />
            <stroke
                android:width="3dp"
                android:color="@color/poetry_primary" />
        </shape>
    </item>
</layer-list>
