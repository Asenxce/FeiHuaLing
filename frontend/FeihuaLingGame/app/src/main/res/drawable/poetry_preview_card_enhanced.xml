<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外层阴影 -->
    <item android:right="0dp" android:left="0dp" android:top="0dp" android:bottom="2dp">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#0A000000" />
        </shape>
    </item>
    
    <!-- 中层阴影 -->
    <item android:right="0dp" android:left="0dp" android:top="0dp" android:bottom="4dp">
        <shape>
            <corners android:radius="14dp" />
            <solid android:color="#14000000" />
        </shape>
    </item>
    
    <!-- 内层阴影 -->
    <item android:right="0dp" android:left="0dp" android:top="0dp" android:bottom="6dp">
        <shape>
            <corners android:radius="12dp" />
            <solid android:color="#1F000000" />
        </shape>
    </item>
    
    <!-- 主体卡片 -->
    <item android:bottom="8dp">
        <shape>
            <corners android:radius="10dp" />
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="0.5dp"
                android:color="#E8E0D4" />
        </shape>
    </item>
</layer-list>