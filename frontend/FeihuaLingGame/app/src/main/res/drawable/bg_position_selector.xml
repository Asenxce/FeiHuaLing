<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中状态 -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFF8E1" />
            <corners android:radius="28dp" />
            <stroke android:width="3dp" android:color="@color/poetry_primary" />
        </shape>
    </item>
    
    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#EDE7F6" />
            <corners android:radius="28dp" />
            <stroke android:width="1.5dp" android:color="@color/poetry_primary" />
        </shape>
    </item>
    
    <!-- 默认状态 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="28dp" />
            <stroke android:width="1.5dp" android:color="@color/poetry_divider" />
        </shape>
    </item>
</selector>
