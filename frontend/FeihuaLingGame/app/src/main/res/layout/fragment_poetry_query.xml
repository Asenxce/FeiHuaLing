<?xml version="1.0" encoding="utf-8"?>
<!-- 诗词查询Fragment布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/poetry_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 搜索卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="6dp"
                android:layout_margin="12dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_article"
                        android:contentDescription="诗词查询"
                        android:layout_marginEnd="8dp" />
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="诗词查询"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_primary" />
                </LinearLayout>

                <!-- 搜索框和按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etQueryKeyword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="输入诗词、作者或标题..."
                        android:inputType="text"
                        android:background="@drawable/edit_text_background"
                        android:textSize="15sp"
                        android:textColor="@color/poetry_text_primary"
                        android:textColorHint="@color/poetry_text_secondary"
                        android:padding="12dp"
                        android:layout_marginEnd="10dp" />

                    <Button
                        android:id="@+id/btnSearchPoetry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="搜索"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/btn_primary_bg"
                        android:elevation="4dp"
                        android:stateListAnimator="@null"
                        android:textAllCaps="false"
                        android:backgroundTint="@null"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 每日一诗推荐 -->
            <LinearLayout
                android:id="@+id/layout_daily_poetry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="4dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="每日一诗" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="每日一诗"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_primary"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_daily_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="《静夜思》"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_daily_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="李白 · 唐"
                    android:textSize="12sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_daily_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="床前明月光，疑是地上霜。"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_ink"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- 热门快捷标签 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="热门搜索"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="8dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layout_hot_tags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 搜索历史 -->
            <LinearLayout
                android:id="@+id/layout_search_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="搜索历史"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_secondary" />

                    <TextView
                        android:id="@+id/tv_clear_history"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="清空"
                        android:textSize="12sp"
                        android:textColor="@color/poetry_text_secondary" />
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleLine="false" />
            </LinearLayout>

            <!-- 加载动画 -->
            <ProgressBar
                android:id="@+id/progressLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginTop="40dp"
                style="?android:attr/progressBarStyleLarge" />

            <!-- 空状态占位图 -->
            <include
                android:id="@+id/layout_empty"
                layout="@layout/view_empty_poetry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:visibility="visible" />

            <!-- 结果列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPoetryResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/card_background"
                android:padding="8dp"
                android:clipToPadding="false"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
