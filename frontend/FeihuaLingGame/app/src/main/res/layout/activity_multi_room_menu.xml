<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/poetry_background"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- 顶部标题栏 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/poetry_card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:contentDescription="返回"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="多人约战"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_text_primary"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/activity_horizontal_margin"
        android:gravity="center">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择操作"
            android:textSize="@dimen/text_size_large"
            android:textStyle="bold"
            android:textColor="@color/brown_dark"
            android:layout_marginBottom="@dimen/margin_xlarge" />

        <!-- 创建房间卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_create_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large"
            app:cardCornerRadius="@dimen/radius_large"
            app:cardElevation="@dimen/card_elevation"
            android:foreground="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/padding_large"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_add_circle"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:contentDescription="创建房间" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="创建房间"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="创建新房间并邀请好友加入"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:layout_marginTop="@dimen/margin_tiny" />
                </LinearLayout>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_right"
                    android:layout_marginStart="@dimen/margin_medium"
                    android:contentDescription="进入" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 加入房间卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_join_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large"
            app:cardCornerRadius="@dimen/radius_large"
            app:cardElevation="@dimen/card_elevation"
            android:foreground="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/padding_large"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_enter"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:contentDescription="加入房间" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="加入房间"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="输入房间码加入好友的房间"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:layout_marginTop="@dimen/margin_tiny" />
                </LinearLayout>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_right"
                    android:layout_marginStart="@dimen/margin_medium"
                    android:contentDescription="进入" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 提示文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="提示：房间创建后可以通过分享房间码或邀请好友加入"
            android:textSize="@dimen/text_size_small"
            android:textColor="@color/poetry_text_secondary"
            android:layout_marginTop="@dimen/margin_medium"
            android:gravity="center"
            android:paddingStart="@dimen/padding_medium"
            android:paddingEnd="@dimen/padding_medium" />
    </LinearLayout>
</LinearLayout>
