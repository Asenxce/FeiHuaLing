<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/poetry_background"
    android:fitsSystemWindows="true">

    <!-- 顶部标题栏 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/poetry_card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="返回"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="消息中心"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_text_primary"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 操作按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/btn_mark_all_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="全部已读"
            android:textSize="13sp"
            android:textColor="@color/poetry_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/btn_text_bg"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btn_clear_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="清空已读"
            android:textSize="13sp"
            android:textColor="@color/poetry_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/btn_text_bg" />
    </LinearLayout>

    <!-- 邮件列表（下拉刷新） -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh_mail"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_mail_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:clipToPadding="false"
                android:scrollbars="vertical" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- 空状态提示 -->
        <LinearLayout
            android:id="@+id/tv_mail_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_send"
                android:contentDescription="空消息"
                android:layout_marginBottom="24dp"
                android:alpha="0.4"
                android:tint="@color/poetry_primary" />

            <TextView
                android:id="@+id/tv_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="暂无消息"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_text_secondary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_empty_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="系统通知、好友申请等将显示在这里"
                android:textSize="14sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>

    </FrameLayout>

    <!-- 底部Tab栏 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/poetry_card_background">

        <LinearLayout
            android:id="@+id/layout_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/tab_all"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="全部"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_margin="4dp"
                android:background="@drawable/btn_primary_bg"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_system"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="系统通知"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:gravity="center"
                android:layout_margin="4dp"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_friend_request"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="好友申请"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:gravity="center"
                android:layout_margin="4dp"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_battle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="对战邀请"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:gravity="center"
                android:layout_margin="4dp"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
