<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/poetry_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/poetry_card_background"
        android:elevation="1dp"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:padding="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="多人对战"
            android:textSize="18sp"
            android:textColor="@color/poetry_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="60dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="60"
            android:textSize="20sp"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:background="@drawable/bg_input" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/poetry_card_background"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_keyword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关键字: --"
            android:textSize="22sp"
            android:textColor="@color/gold"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_round_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待开始..."
            android:textSize="13sp"
            android:textColor="@color/poetry_text_secondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_broadcast_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        android:background="@color/poetry_background">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" 实时播报"
            android:textSize="13sp"
            android:textColor="@color/poetry_text_secondary"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/sv_broadcast"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@color/poetry_background">

        <TextView
            android:id="@+id/tv_broadcast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="@color/poetry_text_secondary"
            android:lineSpacingExtra="6dp" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/ll_player_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:background="@color/poetry_background">
    </LinearLayout>

    <!-- 功能栏：音量调节 + 求助 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@color/poetry_background">

        <ImageView
            android:id="@+id/iv_volume_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_volume"
            android:contentDescription="音量" />

        <SeekBar
            android:id="@+id/sb_volume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="12dp"
            android:max="100"
            android:progress="80" />

        <Button
            android:id="@+id/btn_help"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="求助(3)"
            android:textSize="13sp"
            android:textColor="@color/gold"
            android:background="@drawable/btn_outline_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:enabled="false" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/poetry_card_background">

        <EditText
            android:id="@+id/et_answer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="输入诗句..."
            android:textSize="16sp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:enabled="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btn_submit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="提交答案"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:background="@drawable/btn_primary_bg"
                android:enabled="false" />

            <LinearLayout
                android:id="@+id/btn_voice_input"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:background="@drawable/btn_primary_bg"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="8dp"
                android:enabled="false">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="语音输入" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
