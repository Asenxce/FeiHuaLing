<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/poetry_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tv_header_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="对局结算"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="胜利"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/gold"
                android:layout_marginBottom="8dp" />

            <View
                android:layout_width="48dp"
                android:layout_height="3dp"
                android:background="@color/gold"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvTotalScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+30"
                android:textSize="56sp"
                android:textStyle="bold"
                android:textColor="@color/win_green"
                android:letterSpacing="0.05"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:id="@+id/card_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:elevation="2dp"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tv_info_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="模式：单关键字飞花令"
                    android:textSize="15sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_info_keyword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="关键字：「春」"
                    android:textSize="15sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_info_rounds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="回合：5 回合"
                    android:textSize="15sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_info_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="耗时：1分30秒"
                    android:textSize="15sp"
                    android:textColor="@color/poetry_text_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="对战详情"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_text_primary"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/llQuestionDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:background="@color/surface"
        android:elevation="4dp">

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="再来一局"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_primary_bg"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnBackToHome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="返回首页"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_primary_bg" />
    </LinearLayout>

</LinearLayout>
