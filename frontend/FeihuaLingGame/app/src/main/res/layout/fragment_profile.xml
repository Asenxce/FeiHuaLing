<?xml version="1.0" encoding="utf-8"?>
<!-- 个人信息Fragment布局 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/poetry_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 头像区域卡片（暂时隐藏） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:layout_margin="16dp"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/circle_avatar_bg"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:src="@drawable/default_avatar"
                android:elevation="2dp" />

            <Button
                android:id="@+id/btnChangeAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="更换头像"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_primary"
                android:background="@drawable/btn_outline_bg"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                android:layout_marginTop="12dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>

        <!-- 用户信息表单卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="基本信息"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_primary"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/poetry_divider"
                android:layout_marginBottom="16dp" />

            <!-- 用户名 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户名"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入用户名"
                android:inputType="text"
                android:background="@drawable/edit_text_background"
                android:textSize="16sp"
                android:textColor="@color/poetry_text_primary"
                android:textColorHint="@color/poetry_text_secondary"
                android:layout_marginBottom="16dp"
                android:padding="14dp" />

            <!-- 昵称 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="昵称"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNickname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入昵称"
                android:inputType="text"
                android:background="@drawable/edit_text_background"
                android:textSize="16sp"
                android:textColor="@color/poetry_text_primary"
                android:textColorHint="@color/poetry_text_secondary"
                android:layout_marginBottom="16dp"
                android:padding="14dp" />

            <!-- 邮箱 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="邮箱"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入邮箱地址"
                android:inputType="textEmailAddress"
                android:background="@drawable/edit_text_background"
                android:textSize="16sp"
                android:textColor="@color/poetry_text_primary"
                android:textColorHint="@color/poetry_text_secondary"
                android:layout_marginBottom="16dp"
                android:padding="14dp" />

            <!-- 手机号 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手机号"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入手机号"
                android:inputType="phone"
                android:background="@drawable/edit_text_background"
                android:textSize="16sp"
                android:textColor="@color/poetry_text_primary"
                android:textColorHint="@color/poetry_text_secondary"
                android:layout_marginBottom="16dp"
                android:padding="14dp" />

            <!-- 个性签名 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="个性签名"
                android:textSize="14sp"
                android:textColor="@color/poetry_text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="写一句个性签名吧..."
                android:inputType="textMultiLine"
                android:minLines="3"
                android:maxLines="5"
                android:gravity="top|start"
                android:background="@drawable/edit_text_background"
                android:textSize="16sp"
                android:textColor="@color/poetry_text_primary"
                android:textColorHint="@color/poetry_text_secondary"
                android:padding="14dp" />
        </LinearLayout>

        <!-- 保存按钮 -->
        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="保存资料"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/btn_primary_bg"
            android:elevation="4dp"
            android:stateListAnimator="@null"
            android:layout_margin="16dp"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>
