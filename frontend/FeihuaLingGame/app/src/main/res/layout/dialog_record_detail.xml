<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_white"
    android:padding="20dp"
    android:minWidth="300dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="对战详情"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/poetry_text_primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_battle_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="游戏模式"
        android:textSize="15sp"
        android:textColor="@color/poetry_text_primary"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tv_battle_keyword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="关键字: "
        android:textSize="13sp"
        android:textColor="@color/poetry_text_secondary"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tv_battle_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="时间: "
        android:textSize="13sp"
        android:textColor="@color/poetry_text_secondary"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tv_battle_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="时长: "
        android:textSize="13sp"
        android:textColor="@color/poetry_text_secondary"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="诗句详情"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/poetry_text_primary"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="200dp">

        <LinearLayout
            android:id="@+id/layout_verses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <Button
        android:id="@+id/btn_close_detail"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="关闭"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:background="@drawable/btn_primary_bg"
        android:layout_marginTop="16dp" />

</LinearLayout>
