<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/base_activity_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/poetry_background">

    <!-- 顶部功能栏 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_background"
        android:elevation="4dp"
        android:paddingTop="32dp"
        android:paddingBottom="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:fitsSystemWindows="true">

        <!-- 左侧：用户信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户名"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_text_primary" />

            <TextView
                android:id="@+id/tv_user_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: --"
                android:textSize="11sp"
                android:textColor="@color/poetry_text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 右侧：积分显示 -->
        <TextView
            android:id="@+id/tv_total_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="积分: 0"
            android:textSize="12sp"
            android:textColor="@color/poetry_text_secondary"
            android:background="@drawable/link_background"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </LinearLayout>

    <!-- 中间内容容器（子类内容将添加到这里） -->
    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_bar"
        android:layout_below="@+id/top_bar" />

    <!-- 底部功能栏 -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_background"
        android:elevation="4dp"
        android:padding="8dp"
        android:paddingBottom="16dp"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:fitsSystemWindows="true">

        <!-- 诗词查询 -->
        <LinearLayout
            android:id="@+id/btn_poetry_query"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iv_poetry_query"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_article"
                android:contentDescription="诗词查询" />

            <TextView
                android:id="@+id/tv_poetry_query_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="诗词查询"
                android:textSize="11sp"
                android:textColor="@color/poetry_text_primary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:background="@color/poetry_divider"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- 好友列表 -->
        <LinearLayout
            android:id="@+id/btn_friend"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iv_friend"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_people"
                android:contentDescription="好友列表" />

            <TextView
                android:id="@+id/tv_friend_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="好友"
                android:textSize="11sp"
                android:textColor="@color/poetry_text_primary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:background="@color/poetry_divider"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- 个人信息 -->
        <LinearLayout
            android:id="@+id/btn_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iv_profile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_info"
                android:contentDescription="个人信息" />

            <TextView
                android:id="@+id/tv_profile_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的"
                android:textSize="11sp"
                android:textColor="@color/poetry_text_primary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:background="@color/poetry_divider"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- 退出登录 -->
        <LinearLayout
            android:id="@+id/btn_logout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iv_logout"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_send"
                android:contentDescription="退出登录" />

            <TextView
                android:id="@+id/tv_logout_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="退出"
                android:textSize="11sp"
                android:textColor="@color/loss_red"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
