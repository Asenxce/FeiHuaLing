<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@color/poetry_card_background"
    android:layout_margin="4dp">

    <ImageView
        android:id="@+id/iv_avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/default_avatar"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_nickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="玩家昵称"
                android:textSize="16sp"
                android:textColor="@color/poetry_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_host"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="房主"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_tag_gold"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待中"
            android:textSize="12sp"
            android:textColor="@color/text_hint" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_order"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="1"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_circle_gold" />

        <TextView
            android:id="@+id/tv_fault_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="容错:3"
            android:textSize="10sp"
            android:textColor="@color/poetry_text_secondary"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_ready"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_check_green"
        android:visibility="gone"
        android:layout_marginStart="8dp" />
</LinearLayout>
