<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/poetry_background"
    android:fitsSystemWindows="true">

    <!-- 标题栏 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/poetry_card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_top_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="返回"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tvRulesTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="规则详情"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_text_primary"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 内容区域 - 可滚动 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 积分计算规则 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_target"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="积分" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="积分计算规则"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="每题单独计时计分"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_gold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 每题限时：可在模式选择中自定义（默认30秒）"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 每题基础分：10分"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 速度倍率（按单题用时）："
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  • 0~15秒：×2.0"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  • 15秒以上：×1.5"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 单题得分 = 基础分 × 速度倍率"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 模式倍率："
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  • 简易飞花令：×1.0"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  • 位置 / 双关键字飞花令：×1.2"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  • 接龙 / 反令 / 颜色 / 数字 / 自定义飞花令：×1.5"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 未回答/回答错误：0分"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_seal"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 1. 简易飞花令（单关键字） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_book_outline"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="简易飞花令" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="简易飞花令（单关键字）"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="说出包含指定关键字的诗句"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 诗句必须为完整句子，不能是单个汉字"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 不能重复使用已说过的诗句"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 诗句必须在题库中存在，前端验证格式 + 后端搜索确认"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 倍率：×1.0 | 难度较低，适合新手入门练习"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_gold"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- 2. 位置飞花令 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_book_filled"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="位置飞花令" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="位置飞花令"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="关键字必须在诗句中的指定位置出现"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 关键字位置必须精确匹配（如「花」在第3位）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 不能重复使用已说过的诗句"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 倍率：×1.2 | 考验对诗句结构的精准掌握"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_gold"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- 3. 双关键字飞花令 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_book_filled"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="双关键字飞花令" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="双关键字飞花令"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="说出同时包含两个关键字的诗句"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 两个字都必须出现在诗句中（位置不限）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 不能重复使用已说过的诗句"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 倍率：×1.2 | 同时满足两个条件，考验诗词广度"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_gold"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- 4. 首尾接龙飞花令 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_emoji_events"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="首尾接龙飞花令" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="首尾接龙飞花令"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="上一句的尾字是下一句的首字（首尾相接）"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 你回答的首字必须与上一句尾字相同"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 不能重复使用已说过的诗句"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 倍率：×1.5 | 经典玩法，趣味性极强"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_gold"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- 5. 颜色飞花令 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_emoji_events"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="颜色飞花令" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="颜色飞花令"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="说出包含颜色关键字的诗句"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 关键字从颜色字典中随机抽取（红/黄/蓝/绿/白/黑/紫等）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 不能重复使用已说过的诗句"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 倍率：×1.5 | 色彩主题，诗情画意"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_gold"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- 6. 数字飞花令 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_emoji_events"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="数字飞花令" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数字飞花令"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="说出包含数字关键字的诗句"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 关键字从数字字典中随机抽取（一/二/三/四/五/百/千/万等）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 不能重复使用已说过的诗句"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 倍率：×1.5 | 数字入诗，别有韵味"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_gold"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- 7. 反飞花令 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_emoji_events"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="反飞花令" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="反飞花令"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="说出【不包含】指定关键字的诗句"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 禁用字绝对不能出现在诗句中（前端严格校验）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 不能重复使用已说过的诗句"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 倍率：×1.5 | 逆向思维，极具挑战性"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_gold"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- 8. 自定义飞花令 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_emoji_events"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="自定义飞花令" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自定义飞花令"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="通过规则引擎自由组合验证规则"
                    android:textSize="14sp"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 可选的规则组合："
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  - 包含关键字（Contains）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  - 不包含关键字（NotContains）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  - 关键字位置固定（Position）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  - 首尾接龙（ChainStart）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  - 禁止重复诗句（NoRepeat）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  - 最大字数限制（MaxLength）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  - 字数匹配上一句（CharCountMatch）"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 倍率：×1.5 | 自由组合规则，打造专属飞花令体验"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_gold"
                    android:textStyle="italic" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 返回按钮 -->
    <LinearLayout
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_background"
        android:elevation="3dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_back"
            android:layout_marginEnd="10dp"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="返回"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/poetry_text_secondary" />
    </LinearLayout>

</LinearLayout>
