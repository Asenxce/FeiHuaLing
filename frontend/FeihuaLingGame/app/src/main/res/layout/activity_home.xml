<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_zen_gradient"
    android:clickable="false"
    android:focusable="false"
    android:splitMotionEvents="false">

    <!-- 装饰性水墨圆环 -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/circle_border"
        android:alpha="0.08"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="-80dp"
        android:layout_marginTop="-80dp" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/circle_border"
        android:alpha="0.06"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="-60dp"
        android:layout_marginBottom="-60dp" />

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Logo和标题区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="60dp">

            <!-- 飞花令Logo - 折扇 -->
            <ImageView
                android:id="@+id/tvLogo"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/ic_fan"
                android:contentDescription="飞花令Logo"
                android:layout_marginBottom="28dp"
                android:elevation="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/logo_click_ripple" />

            <!-- 游戏标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="飞花令"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_text_primary"
                android:gravity="center"
                android:letterSpacing="0.3"
                android:shadowColor="#204A5A6A"
                android:shadowDx="2"
                android:shadowDy="3"
                android:shadowRadius="6" />

            <!-- 副标题/标语 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="诗词对战 · 以诗会友"
                android:textSize="15sp"
                android:textColor="@color/poetry_text_secondary"
                android:gravity="center"
                android:alpha="0.85"
                android:layout_marginTop="14dp"
                android:letterSpacing="0.1" />

            <!-- 装饰线(朱砂红) -->
            <View
                android:layout_width="100dp"
                android:layout_height="2dp"
                android:background="@color/poetry_seal"
                android:alpha="0.7"
                android:layout_marginTop="28dp" />
        </LinearLayout>

        <!-- 按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- 登录按钮(黛蓝主色) -->
            <Button
                android:id="@+id/btn_home_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开始游戏"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/btn_primary_bg"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:padding="18dp"
                android:layout_marginBottom="18dp" />

            <!-- 注册按钮(竹青强调色) -->
            <Button
                android:id="@+id/btn_home_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="新用户注册"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_secondary_bg"
                android:elevation="3dp"
                android:stateListAnimator="@null"
                android:padding="16dp"
                android:layout_marginBottom="32dp" />

            <!-- 底部说明 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="传承经典诗词文化\n体验趣味飞花对战"
                android:textSize="13sp"
                android:textColor="@color/poetry_text_secondary"
                android:gravity="center"
                android:alpha="0.75"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- 底部版本信息 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textSize="12sp"
        android:textColor="@color/poetry_text_tertiary"
        android:gravity="center"
        android:alpha="0.5"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp" />

</RelativeLayout>
