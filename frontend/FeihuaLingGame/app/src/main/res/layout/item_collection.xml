<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_background"
    android:elevation="4dp"
    android:layout_marginBottom="12dp"
    android:padding="16dp">

    <!-- 标题和作者 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_item_collection_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="诗词标题"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/poetry_text_primary" />

        <TextView
            android:id="@+id/tv_item_collection_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="唐 · 李白"
            android:textSize="12sp"
            android:textColor="@color/poetry_text_secondary" />
    </LinearLayout>

    <!-- 诗词内容预览 -->
    <TextView
        android:id="@+id/tv_item_collection_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="诗词内容预览..."
        android:textSize="14sp"
        android:textColor="@color/poetry_text_primary"
        android:lineSpacingExtra="4dp"
        android:maxLines="3"
        android:ellipsize="end" />
</LinearLayout>
