<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream"
    android:fitsSystemWindows="true">

    <!-- 标题栏 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="@color/poetry_text_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvGameModeTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="选择对战模式"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_text_primary"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 内容区域 - 可滚动 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 模式说明 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择对战模式"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/poetry_text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="不同模式考验不同的诗词功底，选择适合你的挑战吧"
                    android:textSize="13sp"
                    android:textColor="@color/poetry_text_secondary"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- 推荐模式 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="对战模式"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/poetry_primary"
                android:layout_marginBottom="12dp" />

            <!-- 单关键字 -->
            <LinearLayout
                android:id="@+id/btn_simple_mode"
                style="@style/ListItemMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">
            
                <ImageView
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:src="@drawable/ic_keyword_single" />
            
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
            
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="单关键字飞花令"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />
            
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择 1 个关键字进行对战"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:alpha="0.85" />
                </LinearLayout>
            
                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/poetry_text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- 双关键字 -->
            <LinearLayout
                android:id="@+id/btn_classic_double"
                style="@style/ListItemMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:src="@drawable/ic_keyword_double" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="双关键字飞花令"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="诗句包含2个关键字"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:alpha="0.85" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/poetry_text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- 位置飞花令 -->
            <LinearLayout
                android:id="@+id/btn_classic_position"
                style="@style/ListItemMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:src="@drawable/ic_position" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="位置飞花令"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="关键字在第N个字的位置"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:alpha="0.85" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/poetry_text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- 接龙飞花令 -->
            <LinearLayout
                android:id="@+id/btn_entertainment_chain"
                style="@style/ListItemMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:src="@drawable/ic_chain" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="首尾接龙飞花令"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="诗句首字接上句尾字"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:alpha="0.85" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/poetry_text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- 颜色飞花令 -->
            <LinearLayout
                android:id="@+id/btn_entertainment_color"
                style="@style/ListItemMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:src="@drawable/ic_color" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="颜色飞花令"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="诗句需含指定颜色词"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:alpha="0.85" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/poetry_text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- 数字飞花令 -->
            <LinearLayout
                android:id="@+id/btn_entertainment_number"
                style="@style/ListItemMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:src="@drawable/ic_number" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="数字飞花令"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="诗句需含指定数字"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:alpha="0.85" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/poetry_text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- 反飞花令 -->
            <LinearLayout
                android:id="@+id/btn_entertainment_forbidden"
                style="@style/ListItemMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:clickable="true"
                android:focusable="true"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:layout_marginEnd="@dimen/margin_medium"
                    android:src="@drawable/ic_forbidden" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="反飞花令"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/poetry_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="不能使用指定字"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/poetry_text_secondary"
                        android:alpha="0.85" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/poetry_text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
