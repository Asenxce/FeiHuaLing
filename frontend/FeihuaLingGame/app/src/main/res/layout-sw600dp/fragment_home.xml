<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/poetry_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="@dimen/activity_horizontal_margin"
            android:paddingEnd="@dimen/activity_horizontal_margin"
            android:paddingTop="@dimen/padding_large"
            android:paddingBottom="@dimen/padding_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:maxWidth="600dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_white"
                    android:padding="@dimen/padding_large"
                    android:elevation="@dimen/card_elevation"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="下午好"
                        android:textSize="@dimen/text_size_nav"
                        android:textColor="@color/brown_medium" />

                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="诗仙李白"
                        android:textSize="@dimen/text_size_title"
                        android:textStyle="bold"
                        android:textColor="@color/brown_dark"
                        android:layout_marginTop="@dimen/margin_small" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/padding_large"
                    android:layout_marginBottom="@dimen/padding_large">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="飞花令对战"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/brown_dark"
                        android:letterSpacing="0.05" />

                    <View
                        android:layout_width="50dp"
                        android:layout_height="3dp"
                        android:background="@color/gold"
                        android:layout_marginTop="@dimen/margin_tiny"
                        android:layout_marginBottom="@dimen/margin_tiny" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="以诗会友，妙笔生花"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/gray_text"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btn_start_game"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="88dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/padding_large"
                        android:layout_marginEnd="@dimen/margin_small"
                        android:layout_marginBottom="@dimen/margin_small"
                        android:background="@drawable/bg_home_ai"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="@dimen/card_elevation_large">

                        <View
                            android:layout_width="@dimen/avatar_large"
                            android:layout_height="@dimen/avatar_large"
                            android:layout_marginEnd="@dimen/padding_medium"
                            android:background="@drawable/icon_battle_ai" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="人机对战"
                                android:textSize="@dimen/text_size_button"
                                android:textStyle="bold"
                                android:textColor="@color/white" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="选择模式，挑战AI"
                                android:textSize="@dimen/text_size_small"
                                android:textColor="@color/white"
                                android:alpha="0.9"
                                android:layout_marginTop="@dimen/margin_tiny" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/icon_size_small"
                            android:layout_height="@dimen/icon_size_small"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btn_custom_mode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="88dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/padding_large"
                        android:layout_marginStart="@dimen/margin_small"
                        android:layout_marginBottom="@dimen/margin_small"
                        android:background="@drawable/bg_gradient_top_purple"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="@dimen/card_elevation_large">

                        <View
                            android:layout_width="@dimen/avatar_large"
                            android:layout_height="@dimen/avatar_large"
                            android:layout_marginEnd="@dimen/padding_medium"
                            android:background="@drawable/icon_battle_custom" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="自定义飞花令"
                                android:textSize="@dimen/text_size_button"
                                android:textStyle="bold"
                                android:textColor="@color/white" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="自由组合规则，玩法由你定"
                                android:textSize="@dimen/text_size_small"
                                android:textColor="@color/white"
                                android:alpha="0.9"
                                android:layout_marginTop="@dimen/margin_tiny" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/icon_size_small"
                            android:layout_height="@dimen/icon_size_small"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/white" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_multi_battle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="88dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/padding_large"
                    android:background="@drawable/bg_home_multi"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="@dimen/card_elevation_large">

                    <View
                        android:layout_width="@dimen/avatar_large"
                        android:layout_height="@dimen/avatar_large"
                        android:layout_marginEnd="@dimen/padding_medium"
                        android:background="@drawable/icon_battle_friend" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="多人约战"
                            android:textSize="@dimen/text_size_button"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2-6人好友对局，淘汰制"
                            android:textSize="@dimen/text_size_small"
                            android:textColor="@color/white"
                            android:alpha="0.9"
                            android:layout_marginTop="@dimen/margin_tiny" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_white"
                    android:padding="@dimen/padding_large"
                    android:layout_marginTop="@dimen/padding_large"
                    android:elevation="@dimen/card_elevation"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_total_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            android:textColor="@color/gold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="总积分"
                            android:textSize="@dimen/text_size_tiny"
                            android:textColor="@color/gray_text"
                            android:layout_marginTop="@dimen/margin_tiny" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_divider"
                        android:layout_marginStart="@dimen/margin_small"
                        android:layout_marginEnd="@dimen/margin_small" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_battle_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="对战场次"
                            android:textSize="@dimen/text_size_tiny"
                            android:textColor="@color/gray_text"
                            android:layout_marginTop="@dimen/margin_tiny" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_divider"
                        android:layout_marginStart="@dimen/margin_small"
                        android:layout_marginEnd="@dimen/margin_small" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_win_rate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="胜率"
                            android:textSize="@dimen/text_size_tiny"
                            android:textColor="@color/gray_text"
                            android:layout_marginTop="@dimen/margin_tiny" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
